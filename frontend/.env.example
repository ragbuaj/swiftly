# API Configuration
# Use http://localhost:8080/api for local development with Docker or direct Go run
VITE_API_URL=http://localhost:8080/api

# Social Auth Configuration (must match Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Bot Protection (Cloudflare Turnstile)
# Get these from Cloudflare Dashboard: https://dash.cloudflare.com/
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key-here

# Other configurations
VITE_APP_TITLE=Swiftly E-Commerce
